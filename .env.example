# ============================================================
# Zambia GeoHub AI Platform — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to version control.
# ============================================================

# Required — get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY_HERE

# Optional — override the default Claude model
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional — max GeoJSON features to pull per dataset query (default 200)
MAX_FEATURES=200

# Optional — ArcGIS Hub base URL (default shown)
HUB_BASE_URL=https://zmb-geowb.hub.arcgis.com
